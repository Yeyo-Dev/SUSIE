/* To learn more about Typescript configuration file: https://www.typescriptlang.org/docs/handbook/tsconfig-json.html. */
/* To learn more about Angular compiler options: https://angular.dev/reference/configs/angular-compiler-options. */
{
  "compileOnSave": false,
  "compilerOptions": {
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "es2022",
    "moduleResolution": "bundler",
    "baseUrl": "./",
    "paths": {
      "ngx-susie-proctoring": [
        "projects/ngx-susie-proctoring/src/public-api.ts"
      ],
      "@lib": [
        "projects/ngx-susie-proctoring/src/lib"
      ],
      "@lib/*": [
        "projects/ngx-susie-proctoring/src/lib/*"
      ],
      "@lib/services": [
        "projects/ngx-susie-proctoring/src/lib/services"
      ],
      "@lib/services/*": [
        "projects/ngx-susie-proctoring/src/lib/services/*"
      ],
      "@lib/models": [
        "projects/ngx-susie-proctoring/src/lib/models"
      ],
      "@lib/models/*": [
        "projects/ngx-susie-proctoring/src/lib/models/*"
      ],
      "@lib/components": [
        "projects/ngx-susie-proctoring/src/lib/components"
      ],
      "@lib/components/*": [
        "projects/ngx-susie-proctoring/src/lib/components/*"
      ],
      "@lib/helpers": [
        "projects/ngx-susie-proctoring/src/lib/helpers"
      ],
      "@lib/helpers/*": [
        "projects/ngx-susie-proctoring/src/lib/helpers/*"
      ],
      "@lib/utils": [
        "projects/ngx-susie-proctoring/src/lib/utils"
      ],
      "@lib/utils/*": [
        "projects/ngx-susie-proctoring/src/lib/utils/*"
      ]
    }
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "strictTemplates": true
  },
  "files": [],
  "exclude": [
    "node_modules"
  ],
  "references": [
    {
      "path": "./projects/ngx-susie-proctoring/tsconfig.lib.json"
    },
    {
      "path": "./projects/susie-demo/tsconfig.app.json"
    }
  ]
}